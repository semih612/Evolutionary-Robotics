<mujoco model="Hill World">
  <compiler angle="degree" coordinate="local" inertiafromgeom="true" autolimits="true"/>
  <option integrator="RK4" timestep="0.01" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.9" ambient="0.1 0.1 0.1" specular="0.9 0.9 0.9"/>
    <rgba force="1 0 0 1"/>
    <global azimuth="140" elevation="-20"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.3 0.3 0.3" rgb2="0.2 0.2 0.2"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <hfield name="terrain" file="terrain.png" size="20 5 15 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 20" dir="0 0 -1" directional="true"/>
    <geom conaffinity="1" condim="3" material="groundplane" name="floor" size="2.5 5 0.5" type="box" pos="0 0 -0.5"/>
    <geom name="hill" type="hfield" hfield="terrain" material="groundplane"
          pos="22.5 0 0" condim="3" friction="1 0.005 0.0001" conaffinity="1" contype="1"/>
  </worldbody>
</mujoco>